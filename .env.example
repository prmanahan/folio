# Personal Site - Environment Variables
# Copy to .env and fill in real values

# Server
PORT=3000

# Database
DATABASE_URL=data/site.db

# Admin dashboard (used by both cargo run and docker compose)
ADMIN_PASSWORD=changeme

# CORS origin — set to your production domain in production (e.g. https://peter.manahan.io)
# Must be set via fly.toml [env] for production deploys
CORS_ORIGIN=http://localhost:3000

# AI features (optional - chat and job fit analysis)
ANTHROPIC_API_KEY=

# Logging level (tracing — see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
# RUST_LOG=info,site_core=debug
